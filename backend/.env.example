# TenderIQ backend environment.
# Copy to `.env` and fill in. Never commit a real GOOGLE_API_KEY or DB password.

# --- Database (matches docker-compose.yml) ---
DATABASE_URL=

# --- Redis (rate-limit counters; matches docker-compose.yml) ---
REDIS_URL=

# --- File storage (local volume for MVP per Architecture §5.1) ---
STORAGE_DIR=./storage

# --- Upload limits (REQ-001 Preconditions) ---
MAX_UPLOAD_MB=50

# --- Rate limiting (per-company sliding window in Redis) ---
RATE_LIMIT_RPM=60                   # requests per minute per company
# Monthly document upload quota — overrides per-company via companies.monthly_doc_limit
DEFAULT_MONTHLY_DOC_LIMIT=100

# --- Embeddings (Gemini API) ---
# Get a key at https://aistudio.google.com/apikey
# Free tier: 15 RPM, 1500 RPD — fine for dev/small docs.
# Meeting the REQ-001 90s/100-page NFR requires a paid Tier-1 key ($0.15/M tokens).
GOOGLE_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768

# --- CORS (only the Next.js frontend origin; never "*") ---
CORS_ORIGINS=http://localhost:3000
