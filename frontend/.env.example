# Base URL of the TenderIQ FastAPI backend.
# The NEXT_PUBLIC_ prefix exposes this to the browser (intentional — the upload
# client runs in the browser and must call the API directly).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=

# Base URL of the TenderIQ WebSocket endpoint (REQ-009).
# Use ws:// for local dev, wss:// for production.
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
